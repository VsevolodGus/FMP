<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lang="clr-namespace:Bioss.Ultrasound.Core.Resources.Localization;assembly=Bioss.Ultrasound.Core"
    x:Class="Bioss.Ultrasound.Maui.Pages.AboutPage"
    Title="{x:Static lang:AppStrings.Menu_Title}">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="{x:Static lang:AppStrings.AppName}"
               FontSize="Title" />

        <HorizontalStackLayout Spacing="5">
            <Label Text="{x:Static lang:AppStrings.Version}" />
            <Label Text="{Binding Version}" />
        </HorizontalStackLayout>

        <Button Text="{x:Static lang:AppStrings.PrivacyPolicy}"
                Command="{Binding PrivacyCommandCommand}" />

        <Button Text="{x:Static lang:AppStrings.About_Instruction}"
                Command="{Binding OpenInstructionCommand}" />

    </VerticalStackLayout>

</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lang="clr-namespace:Bioss.Ultrasound.Core.Resources.Localization;assembly=Bioss.Ultrasound.Core"
    x:Class="Bioss.Ultrasound.Maui.Pages.DocumentPage"
    Title="{x:Static lang:AppStrings.PrivacyPolicy}">

    <VerticalStackLayout Padding="20" Spacing="10">

        <ScrollView>
            <Label Text="{Binding Text}"
                   Padding="16"
                   LineBreakMode="WordWrap"/>
        </ScrollView>

        <Button Text="{x:Static lang:AppStrings.Button_Ok}"
                Command="{Binding CloseCommand}" />

    </VerticalStackLayout>

</ContentPage>

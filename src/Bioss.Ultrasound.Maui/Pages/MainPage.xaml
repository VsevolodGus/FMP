<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lang="clr-namespace:Bioss.Ultrasound.Core.Resources.Localization;assembly=Bioss.Ultrasound.Core"
    xmlns:xct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:Bioss.Ultrasound.Maui.Controls"
    xmlns:image="clr-namespace:Bioss.Ultrasound.Core.Resources.Localization;assembly=Bioss.Ultrasound.Core"
    x:Class="Bioss.Ultrasound.Maui.Pages.MainPage"
    Title="{x:Static lang:AppStrings.Main_Title}">

    <ContentPage.Behaviors>
        <!-- Авто-старт сканирования при входе -->
        <xct:EventToCommandBehavior EventName="Appearing"
                                   Command="{Binding RestartScanAsyncCommand}" />
    </ContentPage.Behaviors>

    <Grid>

        <!-- ======= STATE: NOT CONNECTED (как на скрине 2) ======= -->
        <Grid RowDefinitions="1*,2*"
              IsVisible="{Binding IsConnected, Converter={StaticResource ReverseBoolConverter}}">

            <Border Grid.Row="0"
            BackgroundColor="White"
            Stroke="#E6E6E6"
            StrokeThickness="1"
            Margin="0"
            Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#80000000" Opacity="0.12" Radius="12" Offset="0,4"/>
                </Border.Shadow>

                <Grid IsClippedToBounds="True">
                    <controls:Pulse AutoStart="{Binding IsConnected, Converter={StaticResource ReverseBoolConverter}}"
                            PulseColor="CornflowerBlue"
                            Speed="10"
                            Source="Bioss.Ultrasound.Core.Resources.Images.bluetooth.png"
                            VerticalOptions="FillAndExpand"
                            HorizontalOptions="FillAndExpand"/>

                    <Label Text="{x:Static lang:AppStrings.BluetoothSearch}"
                   VerticalOptions="End"
                   HorizontalTextAlignment="Center"
                   Padding="16"
                   TextColor="DarkSlateGray"/>
                </Grid>
            </Border>

            <!-- Список устройств -->
            <CollectionView
                Grid.Row="1"
                ItemsSource="{Binding Devices}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                SelectionChangedCommand="{Binding ConnectSelectedAsyncCommand}">

                <CollectionView.EmptyView>
                    <Grid>
                        <Label
                            Text="{x:Static lang:AppStrings.TurnOnYourDevice}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Margin="16"
                            HorizontalTextAlignment="Center"
                            TextColor="Gray"/>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <!-- общий контейнер с горизонтальным padding как в Xamarin -->
                        <Grid Padding="25,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- контент строки -->
                            <HorizontalStackLayout Grid.Row="0"
                                   Spacing="16"
                                   Padding="0,16"
                                   HeightRequest="48">

                                <Image Source="ic_bluetooth.png"
                                    WidthRequest="20"
                                    HeightRequest="20"
                                    VerticalOptions="Center">
                                    <Image.Behaviors>
                                        <xct:IconTintColorBehavior TintColor="Gray" />
                                    </Image.Behaviors>
                                </Image>


                                <Label Text="{Binding Name}"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center"
                                       TextColor="#808080"/>
                            </HorizontalStackLayout>

                            <!-- разделитель: теперь он ограничен padding-ом контейнера -->
                            <BoxView Grid.Row="1"
                     HeightRequest="0.5"
                     BackgroundColor="#CCCCCC"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- ======= STATE: CONNECTED (пока заглушка) ======= -->
        <Grid IsVisible="{Binding IsConnected}" Padding="16">
            <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Connected"
                       FontAttributes="Bold"
                       FontSize="20"
                       HorizontalTextAlignment="Center"/>
                <Button Text="Disconnect"
                        Command="{Binding DisconnectAsyncCommand}"
                        HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
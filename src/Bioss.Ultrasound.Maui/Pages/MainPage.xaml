<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lang="clr-namespace:Bioss.Ultrasound.Core.Resources.Localization;assembly=Bioss.Ultrasound.Core"
    xmlns:xct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:Bioss.Ultrasound.Maui.Controls"
    x:Class="Bioss.Ultrasound.Maui.Pages.MainPage"
    Title="{x:Static lang:AppStrings.Main_Title}">

    <ContentPage.Behaviors>
        <!-- авто-старт сканирования -->
        <xct:EventToCommandBehavior EventName="Appearing"
                                   Command="{Binding RestartScanAsyncCommand}" />
        <!-- если у вас есть AppearingCommand из части записи -->
        <xct:EventToCommandBehavior EventName="Appearing"
                                   Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid>

        <!-- ======= STATE: NOT CONNECTED ======= -->
        <Grid RowDefinitions="1*,2*"
              IsVisible="{Binding IsConnected, Converter={StaticResource ReverseBoolConverter}}">

            <Border Grid.Row="0"
                    BackgroundColor="White"
                    Stroke="#E6E6E6"
                    StrokeThickness="1"
                    Margin="0"
                    Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#80000000" Opacity="0.12" Radius="12" Offset="0,4"/>
                </Border.Shadow>

                <Grid IsClippedToBounds="True">
                    <controls:Pulse AutoStart="{Binding IsConnected, Converter={StaticResource ReverseBoolConverter}}"
                                    PulseColor="CornflowerBlue"
                                    Speed="10"
                                    Source="Bioss.Ultrasound.Core.Resources.Images.bluetooth.png"
                                    VerticalOptions="FillAndExpand"
                                    HorizontalOptions="FillAndExpand"/>

                    <Label Text="{x:Static lang:AppStrings.BluetoothSearch}"
                           VerticalOptions="End"
                           HorizontalTextAlignment="Center"
                           Padding="16"
                           TextColor="DarkSlateGray"/>
                </Grid>
            </Border>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Devices}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                            SelectionChangedCommand="{Binding ConnectSelectedAsyncCommand}">

                <CollectionView.EmptyView>
                    <Grid>
                        <Label Text="{x:Static lang:AppStrings.TurnOnYourDevice}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="16"
                               HorizontalTextAlignment="Center"
                               TextColor="Gray"/>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="25,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <HorizontalStackLayout Grid.Row="0"
                                                   Spacing="16"
                                                   Padding="0,16"
                                                   HeightRequest="48">

                                <Image Source="ic_bluetooth.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Behaviors>
                                        <xct:IconTintColorBehavior TintColor="Gray" />
                                    </Image.Behaviors>
                                </Image>

                                <Label Text="{Binding Name}"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center"
                                       TextColor="#808080"/>
                            </HorizontalStackLayout>

                            <BoxView Grid.Row="1"
                                     HeightRequest="0.5"
                                     BackgroundColor="#CCCCCC"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- ======= STATE: CONNECTED ======= -->
        <Grid RowDefinitions="Auto,3*,2*"
              IsVisible="{Binding IsConnected}">

            <!-- Верхняя панель -->
            <VerticalStackLayout Grid.Row="0" Margin="16,16,16,0" Spacing="8">

                <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*">

                    <!-- Loss -->
                    <VerticalStackLayout Grid.Column="0" Spacing="0">
                        <Label Text="%" FontSize="12" HorizontalOptions="Center"/>
                        <Label Text="{Binding LossPercentage}"
                               FontSize="24"
                               HorizontalOptions="Center"
                               TextColor="{Binding LossPercentage, Converter={StaticResource LossPercentageToColorConverter}}"/>
                        <HorizontalStackLayout Spacing="0" HorizontalOptions="Center">
                            <Label Text="{Binding LossPercentageMinute}" FontSize="12"/>
                            <Label Text="/" FontSize="12"/>
                            <Label Text="{x:Static lang:AppStrings.Unit_min}" FontSize="12"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="LightGray"/>

                    <!-- FHR -->
                    <VerticalStackLayout Grid.Column="2" Spacing="0">
                        <Label Text="FHR" FontSize="12" HorizontalOptions="Center"/>
                        <Label Text="{Binding FHR}" FontSize="24" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <BoxView Grid.Column="3" WidthRequest="1" BackgroundColor="LightGray"/>

                    <!-- TOCO -->
                    <VerticalStackLayout Grid.Column="4" Spacing="0">
                        <Label Text="TOCO" FontSize="12" HorizontalOptions="Center"/>
                        <Label Text="{Binding Toco}" FontSize="24" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <BoxView Grid.Column="5" WidthRequest="1" BackgroundColor="LightGray"/>

                    <!-- FM -->
                    <VerticalStackLayout Grid.Column="6" Spacing="0">
                        <Label Text="FM" FontSize="12" HorizontalOptions="Center"/>
                        <Label Text="{Binding FetalMovements}" FontSize="24" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Grid>

                <controls:ErrorView
                    Text="{x:Static lang:AppStrings.WarningLowBatteryLevel}"
                    IsVisible="{Binding IsLowBatteryLevel}"/>

                <controls:ErrorView
                    Text="{x:Static lang:AppStrings.WarningLossData}"
                    IsVisible="{Binding IsLossData}"/>

            </VerticalStackLayout>

            <!-- График (пока заглушка). Когда будет MAUI PlotView — замените этот блок на него -->
            <ContentView Grid.Row="1" Grid.RowSpan="2" />

            <!-- Кнопка записи: Tap = Command, LongPress = LongPressCommand -->
            <Border Grid.Row="2"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Margin="0,0,0,30"
                    BackgroundColor="#CCFFFFFF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 32">
                <Border.Shadow>
                    <Shadow Brush="#80000000" Opacity="0.12" Radius="5" Offset="0,2"/>
                </Border.Shadow>

                <Grid x:Name="RecordButtonRoot">
                    <Grid.Behaviors>
                        <xct:TouchBehavior
                            BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}}"
                            Command="{Binding RecordAsyncCommand}"
                            LongPressCommand="{Binding LongPressRecordAsyncCommand}"
                            LongPressDuration="2000"
                            PressedScale="0.96"
                            PressedOpacity="0.8"/>
                    </Grid.Behaviors>

                    <Grid>
                        <Image Source="ic_play.png"
                               Margin="8"
                               HeightRequest="48"
                               WidthRequest="48"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsRecording, Converter={StaticResource ReverseBoolConverter}}">
                            <Image.Behaviors>
                                <xct:IconTintColorBehavior TintColor="Red"/>
                            </Image.Behaviors>
                        </Image>

                        <HorizontalStackLayout Margin="16,8,8,8"
                                               Spacing="0"
                                               IsVisible="{Binding IsRecording}">
                            <Label Text="{Binding RecordTimePassed}"
                                   VerticalOptions="Center"
                                   FontSize="18"/>

                            <Image Source="ic_stop.png"
                                   HeightRequest="48"
                                   WidthRequest="48"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center">
                                <Image.Behaviors>
                                    <xct:IconTintColorBehavior TintColor="Red"/>
                                </Image.Behaviors>
                            </Image>
                        </HorizontalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <!-- Биометрика -->
            <Border Grid.Row="2"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="30"
                    BackgroundColor="#CCFFFFFF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 32"
                    IsVisible="{Binding IsRecording}">
                <Border.Shadow>
                    <Shadow Brush="#80000000" Opacity="0.12" Radius="5" Offset="0,2"/>
                </Border.Shadow>

                <Grid x:Name="BiometricRoot">
                    <Grid.Behaviors>
                        <xct:TouchBehavior
                            BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}}"
                            Command="{Binding BiometricCommand}"
                            PressedScale="0.96"
                            PressedOpacity="0.8"/>
                    </Grid.Behaviors>

                    <Image Source="ic_account_edit.png"
                           Margin="16"
                           HeightRequest="32"
                           WidthRequest="32"
                           VerticalOptions="Center"
                           HorizontalOptions="Center">
                        <Image.Behaviors>
                            <xct:IconTintColorBehavior TintColor="DarkSlateGray"/>
                        </Image.Behaviors>
                    </Image>
                </Grid>
            </Border>

            <!-- Reset FM -->
            <Border Grid.Row="1"
                    Margin="20"
                    VerticalOptions="End"
                    HorizontalOptions="End"
                    BackgroundColor="NavajoWhite"
                    WidthRequest="36"
                    HeightRequest="36"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18">
                <Border.Shadow>
                    <Shadow Brush="#80000000" Opacity="0.12" Radius="5" Offset="0,2"/>
                </Border.Shadow>

                <Grid x:Name="ResetFmRoot">
                    <Grid.Behaviors>
                        <xct:TouchBehavior
                            BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}}"
                            Command="{Binding ResetFMCommand}"
                            PressedScale="0.95"
                            PressedOpacity="0.8"/>
                    </Grid.Behaviors>

                    <Image Source="vibro.png"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Reset TOCO -->
            <Border Grid.Row="2"
                    Margin="20"
                    VerticalOptions="Start"
                    HorizontalOptions="End"
                    BackgroundColor="NavajoWhite"
                    WidthRequest="36"
                    HeightRequest="36"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18">
                <Border.Shadow>
                    <Shadow Brush="#80000000" Opacity="0.12" Radius="5" Offset="0,2"/>
                </Border.Shadow>

                <Grid x:Name="ResetTocoRoot">
                    <Grid.Behaviors>
                        <xct:TouchBehavior
                            BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}}"
                            Command="{Binding ResetTocoAsyncCommand}"
                            PressedScale="0.95"
                            PressedOpacity="0.8"/>
                    </Grid.Behaviors>

                    <Image Source="baseline.png"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Grid>
            </Border>

        </Grid>

    </Grid>
</ContentPage>
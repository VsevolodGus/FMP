<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lang="clr-namespace:Bioss.Ultrasound.Core.Resources.Localization;assembly=Bioss.Ultrasound.Core"
    x:Class="Bioss.Ultrasound.Maui.Pages.MenuPage"
    Title="{x:Static lang:AppStrings.Menu_Title}">

    <CollectionView
        SelectionMode="Single"
        ItemsSource="{Binding Settings}"
        SelectedItem="{Binding SelectedSetting, Mode=TwoWay}">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <VerticalStackLayout Padding="16,12" Spacing="4">

                    <Label
                        Text="{Binding Name}"
                        FontSize="16"
                        FontAttributes="Bold" />

                    <Label
                        Text="{Binding Description}"
                        FontSize="12"
                        TextColor="Gray" />

                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>

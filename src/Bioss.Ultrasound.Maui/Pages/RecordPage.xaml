<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Bioss.Ultrasound.Maui.Pages.RecordPage"
    Title="Record">

    <VerticalStackLayout
        Padding="30"
        Spacing="20"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <Label
            Text="Record Page"
            FontSize="26"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center" />

        <Label
            Text="Graph and recording logic will be connected here"
            FontSize="14"
            HorizontalTextAlignment="Center" />

        <Button
            Text="Start"
            />

        <Button
            Text="Stop"
            />

    </VerticalStackLayout>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lang="clr-namespace:Bioss.Ultrasound.Resources.Localization"
             x:Class="Bioss.Ultrasound.UI.Pages.AboutPage"
             Title="{x:Static lang:AppStrings.Menu_Title}">
    
    <StackLayout Margin="20">

        <Label Text="{x:Static lang:AppStrings.AppName}" 
               FontSize="Title"/>

        <StackLayout Orientation="Horizontal">
            <Label Text="{x:Static lang:AppStrings.Version}"/>
            <Label Text="{Binding Version}"/>
        </StackLayout>

        <Button Text="{x:Static lang:AppStrings.PrivacyPolicy}"
                Command="{Binding PrivacyCommand}"/>

        <Button Text="{x:Static lang:AppStrings.About_Instruction}"
         Command="{Binding OpenInstruction}"/>

    </StackLayout>
    
</ContentPage>